# Scheduled syncs, run by Supercronic on the Fly.io `cron` Machine
# (spawned by scripts/cron-server.js — see [processes] in fly.toml).
# Deployed with the app image on every `fly deploy` — no manual scheduling
# scripts. The same Machine also serves the admin Jobs tab's on-demand
# triggers over private networking.
#
# Every job goes through scripts/run-job.js, which records the run and its
# logs in the job_runs table (visible in the admin portal's Jobs tab).
# Job definitions live in services/jobRegistry.js.
#
# All times below are UTC (Fly Machines run UTC). Scheduled work is confined
# to 1:30–5:00 AM Afghanistan time (Asia/Kabul = UTC+4:30), i.e. 21:00–
# 00:30 UTC. Supercronic skips a run if the previous run of the same job is
# still going, and run-job.js records a 'skipped' row if another run of the
# same job is active.

# Cache refresh during the overnight window (1:30, 2:30, 3:30, 4:30 AM AFT).
# People, current Ding numbers, Applicants, ApplicantReviews, and Drive voice
# memo metadata. Classroom is excluded unless HOURLY_CACHE_INCLUDE_CLASSROOM=true
# is set in fly.toml [env].
0 21,22,23,0 * * * node scripts/run-job.js hourly-cache

# Daily Google Classroom sync (rosters, grades, Ding change history).
# 2:00 AM Afghanistan time (21:30 UTC). Requires classroom.enabled=true.
30 21 * * * node scripts/run-job.js classroom-sync

# Daily voice memo sync from Google Drive to the Applicants sheet.
# 4:00 AM Afghanistan time (23:30 UTC).
30 23 * * * node scripts/run-job.js voice-memo-sync
