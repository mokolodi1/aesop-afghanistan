{
  "name": "aesop-afghanistan",
  "version": "1.0.0",
  "description": "AESOP Afghanistan organization management scripts",
  "main": "server.js",
  "scripts": {
    "build:client": "esbuild src/client/app.jsx --bundle --minify --outfile=public/app.js",
    "build": "npm run build:client",
    "start": "node server.js",
    "dev": "npm run build:client && node server.js",
    "dev:client": "esbuild src/client/app.jsx --bundle --outfile=public/app.js --watch",
    "sync:past-ding-columns": "node scripts/sync-all-past-ding-columns.js",
    "sync:classroom": "node scripts/sync-classroom.js",
    "db:migrate": "node db/migrate.js",
    "db:mirror-people": "node scripts/mirror-people-ding.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "drizzle-orm": "^0.45.2",
    "express": "^4.18.2",
    "google-auth-library": "^9.0.0",
    "google-spreadsheet": "^4.1.0",
    "googleapis": "^144.0.0",
    "helmet": "^7.1.0",
    "luxon": "^3.7.2",
    "nodemailer": "^6.9.7",
    "pg": "^8.22.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.25.11"
  },
  "keywords": [],
